.room-page {
  padding-bottom: 48rpx;
}

.room-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.room-code {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.header-actions {
  width: 200rpx;
  flex: none;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.mini-btn {
  width: 200rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 26rpx;
}

.section {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
}

.player-scroll {
  width: 100%;
  white-space: nowrap;
}

.players {
  display: flex;
  gap: 24rpx;
}

.player {
  width: 144rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.player.is-me {
  opacity: 0.5;
}

.player-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #eaf2ff;
  color: #1677ff;
  font-size: 38rpx;
  font-weight: 700;
}

.player-avatar.small {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  font-size: 30rpx;
  flex: none;
}

.player-name {
  width: 144rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
}

.empty {
  padding: 24rpx 0;
  text-align: center;
}

.record {
  display: flex;
  justify-content: space-between;
  align-items: center;
  min-height: 72rpx;
  border-bottom: 1rpx solid #eef1f5;
  font-size: 28rpx;
}

.score-down {
  color: #d93025;
  font-weight: 700;
}

.modal {
  position: fixed;
  inset: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  background: rgba(0, 0, 0, 0.28);
}

.dialog {
  width: 100%;
  max-width: 640rpx;
  box-sizing: border-box;
  padding: 32rpx;
  border-radius: 16rpx;
  background: #ffffff;
}

.dialog-title {
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
}

.compact {
  width: 100%;
  margin-bottom: 24rpx;
}

.amount-input,
.batch-input {
  height: 80rpx;
  box-sizing: border-box;
  padding: 0 20rpx;
  border: 1rpx solid #dce3ee;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.dialog-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.dialog-actions button {
  flex: 1;
}

.batch-list {
  max-height: 520rpx;
}

.batch-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #eef1f5;
}

.batch-name {
  flex: 1;
  min-width: 0;
}

.batch-input {
  width: 150rpx;
  text-align: right;
}
