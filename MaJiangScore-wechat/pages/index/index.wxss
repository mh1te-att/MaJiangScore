.user {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 20rpx;
}

.avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 56rpx;
  flex: none;
}

.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #eaf2ff;
  color: #1677ff;
  font-size: 44rpx;
  font-weight: 700;
}

.user-main {
  min-width: 0;
}

.nickname {
  font-size: 38rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.stats {
  display: flex;
  margin-bottom: 20rpx;
}

.stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-value {
  font-size: 34rpx;
  font-weight: 700;
}

.actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.join-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.room-input {
  flex: 1;
  height: 88rpx;
  box-sizing: border-box;
  padding: 0 24rpx;
  border: 1rpx solid #dce3ee;
  border-radius: 12rpx;
  background: #ffffff;
  font-size: 30rpx;
}

.modal {
  position: fixed;
  inset: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  background: rgba(0, 0, 0, 0.28);
}

.dialog {
  width: 100%;
  max-width: 640rpx;
  box-sizing: border-box;
  padding: 32rpx;
  border-radius: 16rpx;
  background: #ffffff;
}

.dialog-title {
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
}

.dialog-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.dialog-actions button {
  flex: 1;
}
