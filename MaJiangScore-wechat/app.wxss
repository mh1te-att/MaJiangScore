page {
  min-height: 100vh;
  background: #f5f7fb;
  color: #20242a;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx;
}

.panel {
  background: #ffffff;
  border: 1rpx solid #e8ecf2;
  border-radius: 16rpx;
  padding: 28rpx;
}

.primary-btn,
.secondary-btn {
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  line-height: 88rpx;
}

.primary-btn {
  background: #1677ff;
  color: #ffffff;
}

.secondary-btn {
  background: #eef4ff;
  color: #1677ff;
}

.muted {
  color: #7a7f87;
}
